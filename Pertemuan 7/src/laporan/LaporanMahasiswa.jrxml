<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="LaporanMahasiswa"
              pageWidth="842"
              pageHeight="595"
              orientation="Landscape"
              columnWidth="782"
              leftMargin="30"
              rightMargin="30"
              topMargin="20"
              bottomMargin="20">

    <!-- ==========================================
         FIELDS - Kolom dari database
    =========================================== -->
    <field name="id"      class="java.lang.Integer"/>
    <field name="nim"     class="java.lang.String"/>
    <field name="nama"    class="java.lang.String"/>
    <field name="jurusan" class="java.lang.String"/>
    <field name="ipk"     class="java.lang.Double"/>

    <!-- ==========================================
         VARIABLE - Hitung total & rata-rata
    =========================================== -->
    <variable name="totalIPK" class="java.lang.Double"
              calculation="Sum">
        <variableExpression><![CDATA[$F{ipk}]]></variableExpression>
    </variable>

    <variable name="jumlahMhs" class="java.lang.Integer"
              calculation="Count">
        <variableExpression><![CDATA[$F{id}]]></variableExpression>
    </variable>

    <!-- ==========================================
         TITLE BAND - Judul Laporan
    =========================================== -->
    <title>
        <band height="90" splitType="Stretch">

            <!-- Background Header -->
            <rectangle>
                <reportElement x="0" y="0" width="782" height="90"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
                <box>
                    <pen lineWidth="0.0"/>
                </box>
            </rectangle>

            <!-- Judul Utama -->
            <staticText>
                <reportElement x="0" y="5" width="782" height="30"
                               forecolor="#003366"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[LAPORAN DATA MAHASISWA]]></text>
            </staticText>

            <!-- Sub Judul -->
            <staticText>
                <reportElement x="0" y="35" width="782" height="20"
                               forecolor="#003366"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="12" isBold="false"/>
                </textElement>
                <text><![CDATA[Universitas Pamulang - Program Studi Teknik Informatika]]></text>
            </staticText>

            <!-- Garis bawah header -->
            <line>
                <reportElement x="0" y="60" width="782" height="1"
                               forecolor="#003366"/>
                <graphicElement>
                    <pen lineWidth="2.0"/>
                </graphicElement>
            </line>

            <!-- Tanggal Cetak -->
            <textField pattern="dd MMMM yyyy HH:mm:ss">
                <reportElement x="0" y="65" width="782" height="20"/>
                <textElement textAlignment="Center">
                    <font fontName="Arial" size="10" isItalic="true"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[new java.util.Date()]]>
                </textFieldExpression>
            </textField>

        </band>
    </title>

    <!-- ==========================================
         COLUMN HEADER BAND - Header Tabel
    =========================================== -->
    <columnHeader>
        <band height="30" splitType="Stretch">

            <!-- Background header kolom -->
            <rectangle>
                <reportElement x="0" y="0" width="782" height="30"
                               backcolor="#003366" forecolor="#003366"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>

            <!-- No -->
            <staticText>
                <reportElement x="0" y="0" width="40" height="30"
                               forecolor="#FFFFFF" backcolor="#003366" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[No]]></text>
            </staticText>

            <!-- NIM -->
            <staticText>
                <reportElement x="40" y="0" width="120" height="30"
                               forecolor="#FFFFFF" backcolor="#003366" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[NIM]]></text>
            </staticText>

            <!-- Nama -->
            <staticText>
                <reportElement x="160" y="0" width="250" height="30"
                               forecolor="#FFFFFF" backcolor="#003366" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Nama Mahasiswa]]></text>
            </staticText>

            <!-- Jurusan -->
            <staticText>
                <reportElement x="410" y="0" width="250" height="30"
                               forecolor="#FFFFFF" backcolor="#003366" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Jurusan]]></text>
            </staticText>

            <!-- IPK -->
            <staticText>
                <reportElement x="660" y="0" width="122" height="30"
                               forecolor="#FFFFFF" backcolor="#003366" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[IPK]]></text>
            </staticText>

        </band>
    </columnHeader>

    <!-- ==========================================
         DETAIL BAND - Isi Data Per Baris
    =========================================== -->
    <detail>
        <band height="25" splitType="Stretch">

            <!-- Nomor urut -->
            <textField>
                <reportElement x="0" y="0" width="40" height="25"/>
                <box>
                    <pen lineWidth="0.5" lineColor="#CCCCCC"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="10"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$V{REPORT_COUNT}]]>
                </textFieldExpression>
            </textField>

            <!-- NIM -->
            <textField>
                <reportElement x="40" y="0" width="120" height="25"/>
                <box>
                    <pen lineWidth="0.5" lineColor="#CCCCCC"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="10"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$F{nim}]]>
                </textFieldExpression>
            </textField>

            <!-- Nama -->
            <textField>
                <reportElement x="160" y="0" width="250" height="25"/>
                <box>
                    <pen lineWidth="0.5" lineColor="#CCCCCC"/>
                </box>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font fontName="Arial" size="10"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$F{nama}]]>
                </textFieldExpression>
            </textField>

            <!-- Jurusan -->
            <textField>
                <reportElement x="410" y="0" width="250" height="25"/>
                <box>
                    <pen lineWidth="0.5" lineColor="#CCCCCC"/>
                </box>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font fontName="Arial" size="10"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$F{jurusan}]]>
                </textFieldExpression>
            </textField>

            <!-- IPK -->
            <textField pattern="0.00">
                <reportElement x="660" y="0" width="122" height="25"/>
                <box>
                    <pen lineWidth="0.5" lineColor="#CCCCCC"/>
                </box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="10"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$F{ipk}]]>
                </textFieldExpression>
            </textField>

        </band>
    </detail>

    <!-- ==========================================
         SUMMARY BAND - Footer / Ringkasan
    =========================================== -->
    <summary>
        <band height="60" splitType="Stretch">

            <!-- Garis atas summary -->
            <line>
                <reportElement x="0" y="5" width="782" height="1"
                               forecolor="#003366"/>
                <graphicElement>
                    <pen lineWidth="1.5"/>
                </graphicElement>
            </line>

            <!-- Label Total Mahasiswa -->
            <staticText>
                <reportElement x="160" y="10" width="250" height="20"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Arial" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Total Mahasiswa :]]></text>
            </staticText>

            <!-- Value Total Mahasiswa -->
            <textField>
                <reportElement x="410" y="10" width="100" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font fontName="Arial" size="11" isBold="true"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$V{jumlahMhs} + " Mahasiswa"]]>
                </textFieldExpression>
            </textField>

            <!-- Label Rata-rata IPK -->
            <staticText>
                <reportElement x="160" y="32" width="250" height="20"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Arial" size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[Rata-rata IPK :]]></text>
            </staticText>

            <!-- Value Rata-rata IPK -->
            <textField pattern="0.00">
                <reportElement x="410" y="32" width="100" height="20"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font fontName="Arial" size="11" isBold="true"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA[$V{totalIPK} / $V{jumlahMhs}]]>
                </textFieldExpression>
            </textField>

        </band>
    </summary>

</jasperReport>